{
  "name": "xmlify-tools",
  "version": "0.1.0",
  "description": "Transparent JSON↔XML translation layer for LLM tool calling. Models prefer XML — your framework speaks JSON.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/run.ts",
    "bench:dry": "tsx bench/run.ts --dry-run"
  },
  "keywords": [
    "llm",
    "xml",
    "json",
    "tool-calling",
    "function-calling",
    "ai",
    "agents",
    "schema"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
